# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── API Server ─────────────────────────────────────────────────────────────────
API_PORT=3000

# ─── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-256-bit-random-secret
JWT_EXPIRES_IN=24h

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=smartvill
POSTGRES_PASSWORD=smartvill_password
POSTGRES_DB=smartvill

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── SmartBill ──────────────────────────────────────────────────────────────────
SMARTBILL_BASE_URL=https://www.smartbill.co.kr
